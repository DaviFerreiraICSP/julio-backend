# Servidor
PORT=3001

# JWT - gere um segredo forte (ex: openssl rand -hex 64)
JWT_SECRET=troque_por_um_segredo_forte

# Email (SMTP) - para recuperacao de senha
# Gmail: ative "Senhas de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_aqui

# Stripe (pagamento com cartao)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173
